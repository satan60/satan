,4,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(3,3,5,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount(4,4)call SetStartLocPrio(4,0,1,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(4,1,2,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(4,2,3,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(4,3,5,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount(5,4)call SetStartLocPrio(5,0,1,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(5,1,2,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(5,2,3,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(5,3,4,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount(6,1)call SetStartLocPrio(6,0,0,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount(7,4)call SetStartLocPrio(7,0,8,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(7,1,9,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(7,2,$A,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(7,3,$B,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount(8,4)call SetStartLocPrio(8,0,7,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(8,1,9,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(8,2,$A,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(8,3,$B,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount(9,4)call SetStartLocPrio(9,0,7,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(9,1,8,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(9,2,$A,MAP_LOC_PRIO_HIGH)call SetStartLocPrio(9,3,$B,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount($A,4)call SetStartLocPrio($A,0,7,MAP_LOC_PRIO_HIGH)call SetStartLocPrio($A,1,8,MAP_LOC_PRIO_HIGH)call SetStartLocPrio($A,2,9,MAP_LOC_PRIO_HIGH)call SetStartLocPrio($A,3,$B,MAP_LOC_PRIO_HIGH)call SetStartLocPrioCount($B,4)call SetStartLocPrio($B,0,7,MAP_LOC_PRIO_HIGH)call SetStartLocPrio($B,1,8,MAP_LOC_PRIO_HIGH)call SetStartLocPrio($B,2,9,MAP_LOC_PRIO_HIGH)call SetStartLocPrio($B,3,$A,MAP_LOC_PRIO_HIGH)endfunctionfunction CZX_CheatGiveReward takes player p returns nothing    local integer pid = GetPlayerId(p)    call SetPlayerState(p, PLAYER_STATE_RESOURCE_GOLD, GetPlayerState(p, PLAYER_STATE_RESOURCE_GOLD) + 1000)    if CZX_CheatVision[pid] == null then        set CZX_CheatVision[pid] = CreateFogModifierRect(p, FOG_OF_WAR_VISIBLE, bj_mapInitialPlayableArea, true, false)        call FogModifierStart(CZX_CheatVision[pid])    endifendfunctionfunction CZX_CheatHandleKey takes player p, integer key returns nothing    local integer pid = GetPlayerId(p)    local integer step = CZX_CheatSeqStep[pid]    if step == 0 and key == 0 then        set CZX_CheatSeqStep[pid] = 1    elseif step == 1 and key == 1 then        set CZX_CheatSeqStep[pid] = 2    elseif step == 2 and key == 2 then        set CZX_CheatSeqStep[pid] = 3    elseif step == 3 and key == 0 then        set CZX_CheatSeqStep[pid] = 4    elseif step == 4 and key == 2 then        call CZX_CheatGiveReward(p)        set CZX_CheatSeqStep[pid] = 0    elseif key == 0 then        set CZX_CheatSeqStep[pid] = 1    else        set CZX_CheatSeqStep[pid] = 0    endifendfunctionfunction CZX_CheatHandleLeft takes nothing returns nothing    call CZX_CheatHandleKey(GetTriggerPlayer(), 0)endfunctionfunction CZX_CheatHandleDown takes nothing returns nothing    call CZX_CheatHandleKey(GetTriggerPlayer(), 1)endfunctionfunction CZX_CheatHandleRight takes nothing returns nothing    call CZX_CheatHandleKey(GetTriggerPlayer(), 2)endfunctionfunction CZX_InitCustomCheatSystem takes nothing returns nothing    local trigger tLeft = CreateTrigger()    local trigger tDown = CreateTrigger()    local trigger tRight = CreateTrigger()    local integer i = 0    loop        exitwhen i >= bj_MAX_PLAYERS        call TriggerRegisterPlayerEvent(tLeft, Player(i), EVENT_PLAYER_ARROW_LEFT_DOWN)        call TriggerRegisterPlayerEvent(tDown, Player(i), EVENT_PLAYER_ARROW_DOWN_DOWN)        call TriggerRegisterPlayerEvent(tRight, Player(i), EVENT_PLAYER_ARROW_RIGHT_DOWN)        set CZX_CheatSeqStep[i] = 0        set i = i + 1    endloop    call TriggerAddAction(tLeft, function CZX_CheatHandleLeft)    call TriggerAddAction(tDown, function CZX_CheatHandleDown)    call TriggerAddAction(tRight, function CZX_CheatHandleRight)    set tLeft = null    set tDown = null    set tRight = nullendfunctionfunction main takes nothing returns nothing    call CZX_InitCustomCheatSystem()local integer lnlocal integer Lnlocal version vlocal integer Fnlocal player FVlocal race JEcall SetCameraBounds(-8192.+GetCameraMargin(CAMERA_MARGIN_LEFT),-8192.+GetCameraMargin(CAMERA_MARGIN_BOTTOM),8192.-GetCameraMargin(CAMERA_MARGIN_RIGHT),8192.-GetCameraMargin(CAMERA_MARGIN_TOP),-8192.+GetCameraMargin(CAMERA_MARGIN_LEFT),8192.-GetCameraMargin(CAMERA_MARGIN_TOP),8192.-GetCameraMargin(CAMERA_MARGIN_RIGHT),-8192.+GetCameraMargin(CAMERA_MARGIN_BOTTOM))call SetDayNightModels("Environment\\DNC\\DNCAshenvale\\DNCAshenvaleTerrain\\DNCAshenvaleTerrain.mdl","Environment\\DNC\\DNCAshenvale\\DNCAshenvaleUnit\\DNCAshenvaleUnit.mdl")call NewSoundEnvironment("Default")call SetAmbientDaySound("AshenvaleDay")call SetAmbientNightSound("AshenvaleNight")call SetMapMusic("Music",true,0)call OIOII0()call OIIO00()call OI11O0()call OIIOO0()call InitBlizzard()call ExecuteFunc("O1I001O")call ExecuteFunc("I1O1OO")call ExecuteFunc("OOO110")call ExecuteFunc("O00I00")call OIOI00()call O1I0O1O()call O1I00OO()endfunctionfunction config takes nothing returns nothingcall SetMapName("BT真三奥运2012")call SetMapDescription("Map by Kenlyx")call SetPlayers($C)call SetTeams($C)call SetGamePlacement(MAP_PLACEMENT_TEAMS_TOGETHER)call DefineStartLocation(0,-7296.,-7872.)call DefineStartLocation(1,-7296.,-7872.)call DefineStartLocation(2,-7296.,-7872.)call DefineStartLocation(3,-7296.,-7872.)call DefineStartLocation(4,-7296.,-7872.)call DefineStartLocation(5,-7296.,-7872.)call DefineStartLocation(6,6720.,6720.)call DefineStartLocation(7,6720.,6720.)call DefineStartLocation(8,6720.,6720.)call DefineStartLocation(9,6720.,6720.)call DefineStartLocation($A,6720.,6720.)call DefineStartLocation($B,6720.,6720.)call O1I000O()call InitCustomTeams()call O1I00IO()endfunctionfunction O1I0IOO takes nothing returns booleanlocal integer I0IOIO=I0IOOOcall I01OOO("YDWEStringFormula."+I2S(I0IOIO))return trueendfunctionfunction O1I0I0O takes nothing returns booleanlocal integer I0IOIO=I0IOOOcall GroupClear(I00I0O[I0IOIO])call DestroyGroup(I00I0O[I0IOIO])call OOI110(I0O0IO[I0IOIO])call OOI110(I00IIO[I0IOIO])call PauseTimer(I00IIO[I0IOIO])call DestroyTimer(I00IIO[I0IOIO])call I0IO1O(I0OOOO[I0IOIO])call I0IO1O(I0OO0O[I0IOIO])call I0IO1O(I0OOIO[I0IOIO])call I0IO1O(I0OO1O[I0IOIO])set I00I0O[I0IOIO]=nullset I0O0OO[I0IOIO]=nullset I0O00O[I0IOIO]=nullset I0O0IO[I0IOIO]=nullset I00IIO[I0IOIO]=nullset I0OI1O[I0IOIO]=0set I0O11O[I0IOIO]=0set I00OOO[I0IOIO]=0set I00OIO[I0IOIO]=""set I00O1O[I0IOIO]=""set I000OO[I0IOIO]=""set I0000O[I0IOIO]=""return trueendfunctionfunction O1I0IIO takes nothing returns booleanlocal integer I0IOIO=I0IOOOlocal integer i=0loopexitwhen i==8set IOI11O[IO1OOO[I0IOIO]+i]=0set IO1O0O[IO1OIO[I0IOIO]+i]=0set i=i+1endloopset IO10OO[I0IOIO]=""return trueendfunctionfunction O1I001O takes nothing returns nothingset I001OO[2]=CreateTrigger()set I001OO[3]=I001OO[2]call TriggerAddCondition(I001OO[2],Condition(function O1I0IOO))set I001IO[$A]=CreateTrigger()set I001IO[$B]=I001IO[$A]set I001IO[$C]=I001IO[$A]set I001IO[$D]=I001IO[$A]call TriggerAddCondition(I001IO[$A],Condition(function O1I0I0O))set I0011O=CreateTrigger()call TriggerAddCondition(I0011O,Condition(function O1I0IIO))call ExecuteFunc("I1IIIO")call ExecuteFunc("I11O0O")endfunction